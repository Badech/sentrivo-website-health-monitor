# Neon Database URLs
# Get these from your Neon project dashboard: https://console.neon.tech

# Pooled connection for application runtime (use connection pooling)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection for Prisma migrations and CLI operations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Optional: Set to production in production environment
NODE_ENV="development"
