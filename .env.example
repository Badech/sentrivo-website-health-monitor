# Neon Database URLs
# Get these from your Neon project dashboard: https://console.neon.tech

# Pooled connection for application runtime (use connection pooling)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection for Prisma migrations and CLI operations
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Environment
NODE_ENV="development"

# Google PageSpeed Insights API Key (Optional but recommended for real scans)
# Get your API key from: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY="your-pagespeed-api-key-here"

# Google OAuth (Optional - for Search Console and GA4 integrations)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret-here"

# Google Analytics 4 (Optional - for integration features)
GA4_PROPERTY_ID="properties/your-property-id"
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Application URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
